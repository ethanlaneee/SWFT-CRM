# ─── Dependencies ─────────────────────────────────────────────────────────
node_modules/
server/node_modules/
.pnp/
.pnp.js
.yarn/

# ─── Secrets & credentials ────────────────────────────────────────────────
# Never commit anything that smells like a key, secret, or service account.
.env
.env.*
!.env.example
*.env
*.env.local
*.env.development
*.env.production
*.env.test

# Firebase / Google service account keys
serviceAccountKey.json
service-account*.json
firebase-adminsdk-*.json
google-credentials*.json
gcp-credentials*.json

# Generic credential / token files
*-credentials.json
credentials.json
secrets/
secrets.json
*.secret
*.secrets

# Cryptographic material — TLS, signing, SSH
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.cer
*.der
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.ppk

# Cloud / API keys named explicitly so accidents are impossible
stripe-keys*
aws-credentials*
.aws/
.gcloud/

# ─── Firebase local state ─────────────────────────────────────────────────
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
.firebaserc.local

# ─── Build / cache output ─────────────────────────────────────────────────
dist/
build/
.next/
.cache/
.parcel-cache/
.turbo/
.vite/
coverage/
.nyc_output/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Local database / backup files ────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
backup-*.sql
*.bak
*.dump

# ─── Editor / OS junk ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# ─── Claude Code local settings ───────────────────────────────────────────
# Project-shared settings live in .claude/settings.json (commit those).
# Per-developer overrides go in .claude/settings.local.json (don't commit).
.claude/settings.local.json

# ─── Misc / runtime ───────────────────────────────────────────────────────
.tmp/
tmp/
temp/
*.pid
*.seed
*.pid.lock
