ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
PORT=3000

# ── Phone AI Add-on ──────────────────────────────────────────────────────────
# Get your Vapi API key at https://vapi.ai/
VAPI_API_KEY=your-vapi-api-key-here
# Shared secret — set the same value in your Vapi dashboard under "Server URL Secret"
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret-here
# Stripe Price ID for the $39/mo phone add-on (create in Stripe dashboard)
PHONE_ADDON_PRICE_ID=price_phone_addon_monthly
