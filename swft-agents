<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SWFT — AI Agents</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg:#0a0a0a; --surface:#111111; --surface2:#181818;
    --border:#1f1f1f; --border2:#2c2c2c;
    --green:#c8f135; --white:#f0f0f0; --gray:#7a7a7a; --gray2:#444444;
    --blue:#4d9fff; --amber:#f5a623; --red:#ff5252; --purple:#b388ff;
    --sidebar-w:228px;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--white);font-family:'DM Sans',sans-serif;min-height:100vh;display:flex;}

/* ── SIDEBAR ── */
.sidebar{width:var(–sidebar-w);min-height:100vh;background:var(–surface);border-right:1px solid var(–border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:200;transition:transform 0.28s cubic-bezier(0.22,1,0.36,1);}
.sidebar.collapsed{transform:translateX(-100%);}
.logo-wrap{padding:26px 22px 22px;border-bottom:1px solid var(–border);display:flex;align-items:center;justify-content:space-between;}
.logo-mark{font-family:‘Bebas Neue’,sans-serif;font-size:30px;letter-spacing:3px;color:var(–white);line-height:1;}
.logo-mark em{color:var(–green);font-style:normal;}
.logo-sub{font-size:9.5px;color:var(–gray2);letter-spacing:1.8px;margin-top:3px;font-weight:300;}
.collapse-btn{width:28px;height:28px;border-radius:7px;border:1px solid var(–border2);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(–gray);flex-shrink:0;transition:all 0.14s;}
.collapse-btn:hover{background:var(–surface2);color:var(–white);}
.nav{flex:1;padding:16px 10px;display:flex;flex-direction:column;gap:1px;overflow-y:auto;}
.nav-label{font-size:9px;letter-spacing:2.5px;color:var(–gray2);text-transform:uppercase;padding:14px 12px 5px;}
.nav-item{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:9px;cursor:pointer;font-size:13px;font-weight:400;color:var(–gray);transition:background 0.14s,color 0.14s;position:relative;user-select:none;}
.nav-item:hover{background:var(–surface2);color:var(–white);}
.nav-item.active{background:rgba(200,241,53,0.07);color:var(–green);font-weight:500;}
.nav-item.active::before{content:’’;position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:18px;background:var(–green);border-radius:0 3px 3px 0;}
.nav-icon{width:15px;height:15px;flex-shrink:0;opacity:0.8;}
.nav-item.active .nav-icon{opacity:1;}
.nav-badge{margin-left:auto;background:var(–green);color:#0a0a0a;font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:20px;font-family:‘JetBrains Mono’,monospace;}
.nav-divider{height:1px;background:var(–border);margin:8px 12px;}
.sidebar-footer{border-top:1px solid var(–border);padding:12px 10px;}
.user-tile{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:9px;cursor:pointer;transition:background 0.14s;}
.user-tile:hover{background:var(–surface2);}
.s-avatar{width:30px;height:30px;border-radius:50%;background:var(–green);color:#0a0a0a;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.user-name{font-size:12px;font-weight:500;color:var(–white);}
.user-role{font-size:10.5px;color:var(–gray2);margin-top:1px;}
.sidebar-toggle{position:fixed;top:14px;left:14px;z-index:300;width:32px;height:32px;border-radius:8px;background:var(–surface2);border:1px solid var(–border2);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(–gray);transition:all 0.15s;opacity:0;pointer-events:none;}
.sidebar-toggle.visible{opacity:1;pointer-events:all;}
.sidebar-toggle:hover{background:var(–border2);color:var(–white);}

/* ── MAIN ── */
.main{margin-left:var(–sidebar-w);flex:1;display:flex;flex-direction:column;min-height:100vh;transition:margin-left 0.28s cubic-bezier(0.22,1,0.36,1);}
.main.expanded{margin-left:0!important;}

/* ── TOPBAR ── */
.topbar{height:60px;border-bottom:1px solid var(–border);display:flex;align-items:center;padding:0 28px;gap:16px;position:sticky;top:0;background:rgba(10,10,10,0.9);backdrop-filter:blur(14px);z-index:100;}
.topbar-page{font-family:‘Bebas Neue’,sans-serif;font-size:20px;letter-spacing:2.5px;color:var(–white);}
.topbar-slash{color:var(–border2);font-family:‘JetBrains Mono’,monospace;font-size:16px;}
.topbar-sub{font-size:12px;color:var(–gray);font-style:italic;font-weight:300;}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.ai-pill{display:flex;align-items:center;gap:7px;background:rgba(200,241,53,0.07);border:1px solid rgba(200,241,53,0.18);border-radius:20px;padding:5px 13px;font-size:11.5px;font-weight:500;color:var(–green);}
.pulse{width:6px;height:6px;border-radius:50%;background:var(–green);animation:glow 2.2s ease-in-out infinite;}
@keyframes glow{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(200,241,53,0.5);}50%{opacity:0.6;box-shadow:0 0 0 4px rgba(200,241,53,0);}}

/* ── PAGE BODY ── */
.page-body{flex:1;padding:28px 28px 48px;display:flex;flex-direction:column;gap:20px;}

/* ── HERO STRIP ── */
.hero-strip{background:linear-gradient(135deg,rgba(200,241,53,0.06) 0%,rgba(200,241,53,0.02) 100%);border:1px solid rgba(200,241,53,0.14);border-radius:14px;padding:20px 26px;display:flex;align-items:center;gap:18px;}
.hero-icon{font-size:36px;flex-shrink:0;}
.hero-text h2{font-family:‘Bebas Neue’,sans-serif;font-size:22px;letter-spacing:2px;color:var(–white);}
.hero-text p{font-size:13px;color:var(–gray);margin-top:4px;line-height:1.5;}
.hero-stats{margin-left:auto;display:flex;gap:28px;flex-shrink:0;}
.hstat{text-align:right;}
.hstat-val{font-family:‘Bebas Neue’,sans-serif;font-size:26px;letter-spacing:1px;color:var(–green);}
.hstat-label{font-size:10px;color:var(–gray2);letter-spacing:1px;text-transform:uppercase;margin-top:1px;}

/* ── AGENT CARD ── */
.agent-card{background:var(–surface);border:1px solid var(–border);border-radius:16px;overflow:hidden;transition:border-color 0.2s;animation:fadeUp 0.4s ease both;}
.agent-card:nth-child(1){animation-delay:.06s;}
.agent-card:nth-child(2){animation-delay:.13s;}
.agent-card:nth-child(3){animation-delay:.20s;}
.agent-card.expanded{border-color:var(–border2);}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

/* Card header — always visible */
.agent-header{display:flex;align-items:center;gap:16px;padding:20px 22px;cursor:pointer;user-select:none;}
.agent-header:hover .agent-name{color:var(–white);}

.agent-icon-wrap{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}

.agent-info{flex:1;min-width:0;}
.agent-name{font-family:‘Bebas Neue’,sans-serif;font-size:18px;letter-spacing:1.5px;color:var(–white);transition:color 0.14s;}
.agent-desc{font-size:12px;color:var(–gray);margin-top:3px;}

.agent-meta{display:flex;align-items:center;gap:10px;flex-shrink:0;}

/* Toggle switch */
.toggle-wrap{display:flex;align-items:center;gap:8px;}
.toggle-label{font-size:11px;color:var(–gray);}
.toggle{width:38px;height:22px;border-radius:11px;background:var(–border2);position:relative;cursor:pointer;transition:background 0.2s;flex-shrink:0;}
.toggle.on{background:var(–green);}
.toggle::after{content:’’;position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:#0a0a0a;transition:transform 0.2s;}
.toggle.on::after{transform:translateX(16px);}

.activity-badge{font-family:‘JetBrains Mono’,monospace;font-size:10px;font-weight:600;padding:3px 9px;border-radius:6px;background:rgba(200,241,53,0.1);color:var(–green);}
.activity-badge.amber{background:rgba(245,166,35,0.1);color:var(–amber);}

.expand-chevron{color:var(–gray2);transition:transform 0.25s;flex-shrink:0;}
.agent-card.expanded .expand-chevron{transform:rotate(180deg);}

/* Stat row inside header */
.agent-stats{display:flex;gap:20px;padding:0 22px 16px;border-bottom:1px solid var(–border);}
.astat{display:flex;flex-direction:column;}
.astat-val{font-family:‘JetBrains Mono’,monospace;font-size:14px;font-weight:500;color:var(–white);}
.astat-label{font-size:10px;color:var(–gray2);letter-spacing:0.5px;margin-top:2px;}

/* Expandable detail panel */
.agent-detail{max-height:0;overflow:hidden;transition:max-height 0.35s cubic-bezier(0.22,1,0.36,1);}
.agent-card.expanded .agent-detail{max-height:900px;}

.detail-inner{padding:20px 22px;display:flex;flex-direction:column;gap:18px;border-top:1px solid var(–border);}

/* Two-col layout inside detail */
.detail-cols{display:grid;grid-template-columns:1fr 1fr;gap:16px;}

/* Config panel */
.config-panel{background:var(–surface2);border:1px solid var(–border);border-radius:11px;padding:16px;}
.config-title{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(–gray2);margin-bottom:12px;}
.config-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(–border);}
.config-row:last-child{border-bottom:none;}
.config-label{font-size:12.5px;color:var(–gray);}
.config-val{font-size:12.5px;color:var(–white);font-weight:500;}
.config-edit{font-size:11px;color:var(–green);cursor:pointer;font-weight:500;}
.config-edit:hover{text-decoration:underline;}

/* Activity log */
.activity-log{background:var(–surface2);border:1px solid var(–border);border-radius:11px;overflow:hidden;}
.log-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(–border);}
.log-title{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(–gray2);}
.log-link{font-size:11px;color:var(–green);cursor:pointer;font-weight:500;}
.log-item{display:flex;align-items:flex-start;gap:12px;padding:11px 16px;border-bottom:1px solid var(–border);}
.log-item:last-child{border-bottom:none;}
.log-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px;}
.log-body{flex:1;}
.log-text{font-size:12.5px;color:#c8c8c8;line-height:1.4;}
.log-text strong{color:var(–white);}
.log-time{font-family:‘JetBrains Mono’,monospace;font-size:10px;color:var(–gray2);margin-top:3px;}

/* Performance bar */
.perf-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(–border);}
.perf-row:last-child{border-bottom:none;}
.perf-label{font-size:12px;color:var(–gray);flex:1;}
.perf-bar-track{width:100px;height:4px;background:var(–border);border-radius:2px;overflow:hidden;flex-shrink:0;}
.perf-bar-fill{height:100%;border-radius:2px;background:var(–green);}
.perf-pct{font-family:‘JetBrains Mono’,monospace;font-size:11px;color:var(–white);width:36px;text-align:right;flex-shrink:0;}

/* Prompt/script preview */
.prompt-box{background:#0d0d0d;border:1px solid var(–border2);border-radius:9px;padding:14px;font-family:‘JetBrains Mono’,monospace;font-size:11.5px;color:#8aab1f;line-height:1.6;}
.prompt-box .comment{color:var(–gray2);}

::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(–border2);border-radius:2px;}

/* ── TOAST ── */
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);background:var(–surface2);border:1px solid var(–border2);border-radius:10px;padding:11px 20px;font-size:13px;color:var(–white);display:flex;align-items:center;gap:8px;z-index:9999;opacity:0;pointer-events:none;transition:opacity 0.2s,transform 0.2s;white-space:nowrap;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast-dot{width:7px;height:7px;border-radius:50%;background:var(–green);flex-shrink:0;}

/* ── TOPBAR COLLAPSE OFFSET ── */
.topbar { transition: padding-left 0.28s cubic-bezier(0.22,1,0.36,1); }
.main.expanded .topbar { padding-left: 56px; }

</style>
</head>
